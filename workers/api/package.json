{
  "name": "@langerface/cloudflare-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply langerface-dev --local",
    "migrate:remote": "wrangler d1 migrations apply langerface-prod --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260627.1",
    "@types/node": "^24.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
