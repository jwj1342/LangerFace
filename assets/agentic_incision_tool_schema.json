{
  "version": "0.9-agentic-incision-tools",
  "trace_mode": "single_or_multi_round_react_with_deterministic_tools",
  "boundary": "The LLM may select, summarize, and request deterministic tools; it must not compute incision geometry or override guardrails.",
  "trace_gate": {
    "schema_version": "agent-trace-gate/v0.1",
    "blocks_confirmation": true,
    "required_actions": [
      ["summarize_tumor_input_quality"],
      ["classify_region"],
      ["query_rstl_direction"],
      ["linear_subcutaneous_incision", "fusiform_cutaneous_incision"],
      ["evaluate_guardrails"],
      ["preview_incision_on_face"]
    ],
    "boundary": "Candidate confirmation requires deterministic tumor quality, anatomy, RSTL direction, incision generation, guardrail, and face preview observations."
  },
  "orchestration_audit": {
    "schema_version": "agent-orchestration-audit/v0.1",
    "records": ["candidate_count", "preview_count", "preview_ready_count", "comparison_ready", "react_plan_passed", "react_plan_step_count", "retry_count", "retried_failures", "tool_failure_count", "recovered_failures", "trace_gate_passed"],
    "boundary": "Agent orchestration may compare deterministic candidates for review; it must not issue surgical instructions or bypass clinician confirmation."
  },
  "react_plan": {
    "schema_version": "agent-react-plan/v0.1",
    "mode": "single_turn_react_multi_candidate_with_deterministic_tools",
    "steps": [
      "inspect_tumor_input",
      "localize_anatomy",
      "query_direction",
      "generate_primary_candidate",
      "check_guardrails",
      "preview_candidates",
      "compare_direction_variants"
    ],
    "records": ["required_action_groups", "observed_actions", "trace_indexes", "status", "issues"],
    "boundary": "The ReAct plan is an audit scaffold over deterministic tool calls; it is not autonomous clinical reasoning or a surgical instruction."
  },
  "execution_events": {
    "schema_version": "agent-execution-events/v0.1",
    "mode": "single_turn_react_multi_candidate_with_deterministic_tools",
    "records": ["events", "event_count", "tool_event_count", "retry_event_count", "recovery_event_count"],
    "event_fields": ["event", "status", "trace_index", "action", "plan_step_ids", "message"],
    "sse_events": ["execution_event"],
    "boundary": "Execution events replay deterministic tool observations for UI feedback and offline audit; they are not autonomous clinical reasoning or surgical instructions."
  },
  "session": {
    "schema_version": "agentic-incision-session/v0.1",
    "mode": "multi_round_react_session_with_deterministic_tools",
    "round_schema_version": "agentic-incision-session-round/v0.1",
    "audit_schema_version": "agent-session-audit/v0.1",
    "records": ["rounds", "final_candidate_id", "agent_session_audit", "clinical_boundary"],
    "round_records": ["round_index", "trigger", "clinician_feedback", "tumor_delta", "selected_candidate_id", "trace_gate_passed", "react_plan_passed", "plan"],
    "sse_events": ["session_round", "execution_event", "trace", "trace_gate", "react_plan", "session_audit", "result", "done"],
    "boundary": "A session may iterate structured tumor inputs and deterministic plans across clinician-feedback rounds; it must not bypass per-round trace gates, guardrails, or clinician review."
  },
  "trace_audit_executor": {
    "schema_version": "agentic-incision-trace-audit/v0.1",
    "tool": "tools/audit_agentic_incision_trace.py",
    "inputs": ["agentic-incision-plan/v0.1", "agentic-incision-session/v0.1", "incision-review-record/v0.3", "incision-review-export/v0.3"],
    "checks": [
      "agent-trace-gate replay",
      "stored trace gate consistency",
      "agent-react-plan replay",
      "stored react plan consistency",
      "agent-execution-events replay",
      "stored execution events consistency",
      "candidate comparison replay",
      "orchestration audit count consistency",
      "retry_tool_failure trace consistency",
      "recover_tool_failure trace consistency",
      "LLM summary clinician-review boundary",
      "LLM forbidden surgical directive scan",
      "LLM raw provider payload exclusion",
      "provider secret redaction",
      "multi-round session plan expansion"
    ],
    "boundary": "Offline audit verifies deterministic Agentic trace contracts only; it is not clinical validation or a surgical instruction."
  },
  "tools": [
    {
      "name": "classify_region",
      "input": ["point"],
      "output": ["region", "subunit", "confidence", "confidence_reasons", "region_boundary_margin_norm", "nearby_landmarks", "free_margin_distance_mm"]
    },
    {
      "name": "summarize_tumor_input_quality",
      "input": ["tumor"],
      "output": ["passed", "warning_count", "warnings", "source", "boundary_source", "author_present", "units"]
    },
    {
      "name": "query_rstl_direction",
      "input": ["point", "source", "k_nearest"],
      "output": ["vector", "angle_deg", "confidence", "support_count", "angular_spread_deg", "confidence_reasons"]
    },
    {
      "name": "linear_subcutaneous_incision",
      "input": ["tumor", "direction", "units_per_mm", "rules"],
      "output": ["endpoints", "polyline", "length_mm", "metrics", "provenance"]
    },
    {
      "name": "fusiform_cutaneous_incision",
      "input": ["tumor", "direction", "normal", "units_per_mm", "rules"],
      "output": ["outline", "polyline", "length_mm", "width_mm", "metrics", "provenance"]
    },
    {
      "name": "evaluate_guardrails",
      "input": ["candidate", "anatomy", "rules"],
      "output": ["passed", "warnings", "suggested_overrides"]
    },
    {
      "name": "preview_incision_on_face",
      "input": ["candidate", "tumor", "anatomy", "guardrails"],
      "output": ["renderable", "preview_space", "candidate_point_count", "tumor_boundary_point_count", "guardrails_passed", "clinician_review_required"]
    },
    {
      "name": "propose_direction_variants",
      "input": ["direction", "angle_offsets_deg"],
      "output": ["direction_variants", "boundary"]
    },
    {
      "name": "recover_tool_failure",
      "input": ["tool", "variant", "error"],
      "output": ["recovery", "candidate_kept"]
    },
    {
      "name": "retry_tool_failure",
      "input": ["tool", "variant", "error", "attempt"],
      "output": ["retry", "max_attempts", "recovery"]
    },
    {
      "name": "clinician_edit_candidate",
      "input": ["candidate", "angle_offset_deg", "length_scale", "width_scale", "shift_along_mm", "shift_perp_mm", "reason"],
      "output": ["edited_candidate", "guardrails", "provenance"]
    },
    {
      "name": "compare_candidates",
      "input": ["review_records"],
      "output": ["ranked_candidates", "score_breakdown", "clinical_boundary"]
    },
    {
      "name": "save_review_record",
      "input": ["candidate", "tumor", "trace", "privacy_audit", "reviewer", "review_status", "review_notes"],
      "output": ["review_record_json", "report_markdown", "screenshot_png", "guardrail_summary", "review_gate", "audit_events"]
    }
  ]
}
